<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- NuGet package metadata -->
    <PackageId>RpcWatsonTcp</PackageId>
    <Version>0.1.0</Version>
    <Authors>RpcWatsonTcp Contributors</Authors>
    <Description>A .NET RPC framework built on WatsonTcp and Nerdbank.MessagePack.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.0.0" />
    <PackageReference Include="Nerdbank.MessagePack" Version="1.0.43" />
    <PackageReference Include="WatsonTcp" Version="6.0.12" />
  </ItemGroup>

</Project>
